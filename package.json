{
  "name": "sherpy-pm",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=23.0.0"
  },
  "scripts": {
    "dev": "concurrently \"pnpm:dev:api\" \"pnpm:dev:web\"",
    "dev:mode": "DEV_MODE=true VITE_DEV_MODE=true concurrently \"pnpm:dev:api\" \"pnpm:dev:web\"",
    "dev:api": "pnpm --filter @sherpy/api dev",
    "dev:web": "pnpm --filter @sherpy/web dev",
    "build": "pnpm -r run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome check --write .",
    "lint:fix": "biome check --apply .",
    "typecheck": "pnpm -r run typecheck",
    "precommit": "pnpm run lint && pnpm run typecheck && pnpm run test"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@effect/vitest": "^0.13.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^25.6.0",
    "concurrently": "^9.1.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.12.26",
    "@assistant-ui/react-markdown": "^0.12.11",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tanstack/react-query": "^5.100.6",
    "bunshi": "^2.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jotai": "^2.19.1",
    "lucide-react": "^1.12.0",
    "tailwind-merge": "^3.5.0"
  }
}
