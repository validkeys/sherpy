# ============================================
# DEVELOPMENT MODE (bypasses authentication)
# ============================================
# Set to 'true' to run without Okta credentials
# WARNING: This should NEVER be set in production!
# Leave blank or set to 'false' for real authentication
VITE_DEV_MODE=true

# ============================================
# Okta OIDC Configuration (required when VITE_DEV_MODE=false)
# ============================================
# Get these from your Okta application dashboard:
# 1. Create a new SPA application in Okta Admin Console
# 2. Set Sign-in redirect URIs: http://localhost:5173/login/callback
# 3. Set Sign-out redirect URIs: http://localhost:5173
# 4. Enable "Authorization Code" grant type with PKCE
VITE_OKTA_DOMAIN=https://your-domain.okta.com/oauth2/default
VITE_OKTA_CLIENT_ID=your-client-id-here

# ============================================
# API Configuration
# ============================================
# Leave empty for development (uses Vite proxy, avoids CORS)
# Set to your API URL for production (e.g., https://api.sherpy.com)
VITE_API_URL=
