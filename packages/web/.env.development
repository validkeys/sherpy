# Development Environment Configuration

# Backend API URL
# Leave empty to use mock runtime (client-side, no backend needed)
# Set to backend URL to use real backend (e.g., http://localhost:3000)
VITE_BACKEND_URL=

# To enable real backend integration:
# VITE_BACKEND_URL=http://localhost:3000

# Mock runtime is used when VITE_BACKEND_URL is not set
# This allows frontend development and testing without backend dependency
# Messages will be echoed back with simulated AI responses
