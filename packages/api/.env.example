# ============================================
# DEVELOPMENT MODE (bypasses authentication)
# ============================================
# Set to 'true' to run without Okta credentials
# WARNING: This should NEVER be set to 'true' in production!
DEV_MODE=true

# ============================================
# Okta OIDC Configuration (required when DEV_MODE=false)
# ============================================
# Get these from your Okta application dashboard:
# 1. Create a new API application in Okta Admin Console
# 2. Note the "Issuer URI" (usually ends with /oauth2/default)
# 3. Note the Client ID
OKTA_DOMAIN=https://your-domain.okta.com/oauth2/default
OKTA_CLIENT_ID=your-client-id-here

# ============================================
# AWS Bedrock Configuration (for AI chat features)
# ============================================
# AWS region where Bedrock is available
AWS_REGION=ca-central-1

# AWS Profile for SSO (REQUIRED for local development with AWS SSO)
# Set this in your ~/.zshrc or ~/.bashrc:
#   export AWS_PROFILE='your-sso-profile-name'
# Then run: aws sso login --profile your-sso-profile-name
# AWS_PROFILE=your-sso-profile

# Bedrock uses AWS SDK credential provider chain (no access keys needed):
# 1. AWS SSO profile (via AWS_PROFILE) - RECOMMENDED for local dev
# 2. IAM roles (for Kubernetes/EC2) - automatic in production
# 3. Shared credentials file (~/.aws/credentials)
# 4. Environment variables (AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_SESSION_TOKEN)

# Bedrock model ID (optional - defaults to Claude Sonnet 4 via AMER inference profile)
# IMPORTANT: Must use inference profile IDs (with region prefix), NOT direct model IDs
# Available inference profiles in ca-central-1:
# - amer.anthropic.claude-sonnet-4-20250514-v1:0 (Claude Sonnet 4 - AMER cross-region - default)
# Use cross-region inference profiles (amer.*, us.*, eu.*) for best availability
# BEDROCK_DEFAULT_MODEL=amer.anthropic.claude-sonnet-4-20250514-v1:0
# Alternative: BEDROCK_MODEL_ID=amer.anthropic.claude-sonnet-4-20250514-v1:0
